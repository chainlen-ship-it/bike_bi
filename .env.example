# Copy to .env and replace YOUR_PROJECT_ID with your Google Cloud project ID.

ROOT_DIR=backend
SQL_DIR=data/sql
DATA_DIR=data
YEAR_FROM=2015
YOUR_PROJECT=YOUR_PROJECT_ID
GOOGLE_AUTH_LAUNCH=false

# Optional service-account auth alternative. Leave blank when using gcloud ADC.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
